#!/bin/bash
# =====================================================
# Script: ตรวจสอบและแก้ไข DISABLE_WP_CRON ทุกเว็บ
# รองรับ /home, /home2, /home3 ... อัตโนมัติ
# ✅ ป้องกันการเพิ่มซ้ำ + ลบบรรทัดซ้ำอัตโนมัติ
# Usage: bash edit-disable-wordpress
#        bash edit-disable-wordpress /home/jan2026newkey
# =====================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
NC='\033[0m'

# ==================== หา Home Directories ====================

if [[ -n "$1" ]]; then
    SEARCH_PATHS=("$1")
else
    SEARCH_PATHS=()
    for dir in /home /home2 /home3 /home4 /home5; do
        [[ -d "$dir" ]] && SEARCH_PATHS+=("$dir")
    done
fi

echo ""
echo "======================================================"
echo "   DISABLE_WP_CRON - Auto Scanner & Fixer v2"
echo "   ✅ ป้องกันซ้ำ + ลบบรรทัดซ้ำอัตโนมัติ"
echo "======================================================"
echo ""
echo -e "${BLUE}📂 Home directories ที่พบ:${NC}"
for path in "${SEARCH_PATHS[@]}"; do
    echo -e "   ✔ ${CYAN}$path${NC}"
done
echo ""

NOT_DISABLED=()
DISABLED=()
DUPLICATED=()

# ==================== สแกนทุก Path ====================

for SEARCH_PATH in "${SEARCH_PATHS[@]}"; do
    echo -e "${PURPLE}🔍 กำลังสแกน: $SEARCH_PATH${NC}"

    while IFS= read -r config_file; do
        [[ "$config_file" == *backup* ]] && continue
        [[ "$config_file" == *-backup* ]] && continue
        [[ "$config_file" == *.bak* ]] && continue

        domain=$(basename "$(dirname "$config_file")")
        home_label=$(echo "$config_file" | grep -oP '^/home\d*')

        # นับจำนวนบรรทัดที่มี DISABLE_WP_CRON
        cron_count=$(grep -c "DISABLE_WP_CRON" "$config_file" 2>/dev/null)

        if [[ "$cron_count" -gt 1 ]]; then
            # ✅ พบบรรทัดซ้ำ
            DUPLICATED+=("$domain|$config_file|$cron_count|$home_label")
        elif [[ "$cron_count" -eq 1 ]]; then
            if grep -q "define.*DISABLE_WP_CRON.*true" "$config_file" 2>/dev/null; then
                DISABLED+=("$domain|$config_file|$home_label")
            else
                NOT_DISABLED+=("$domain|$config_file|set_but_false|$home_label")
            fi
        else
            NOT_DISABLED+=("$domain|$config_file|not_set|$home_label")
        fi

    done < <(find "$SEARCH_PATH" -name "wp-config.php" \
        -not -path "*/backup*" \
        -not -path "*-backup*" \
        -not -name "*.bak*" \
        2>/dev/null | sort)
done

echo ""

# ==================== แสดงผล: บรรทัดซ้ำ ====================

if [[ ${#DUPLICATED[@]} -gt 0 ]]; then
    echo -e "${YELLOW}⚠️  เว็บที่มี DISABLE_WP_CRON ซ้ำหลายบรรทัด (${#DUPLICATED[@]} เว็บ):${NC}"
    echo "------------------------------------------------------"
    i=1
    for entry in "${DUPLICATED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        config=$(echo "$entry" | cut -d'|' -f2)
        count=$(echo "$entry" | cut -d'|' -f3)
        home_label=$(echo "$entry" | cut -d'|' -f4)
        echo -e "  $i. ${CYAN}$domain${NC} ${PURPLE}[$home_label]${NC} ${YELLOW}[ซ้ำ $count บรรทัด]${NC}"
        ((i++))
    done
    echo ""
fi

# ==================== แสดงผล: ยังไม่ปิด ====================

echo -e "${RED}❌ เว็บที่ยังไม่ได้ปิด (${#NOT_DISABLED[@]} เว็บ):${NC}"
echo "------------------------------------------------------"
if [[ ${#NOT_DISABLED[@]} -eq 0 ]]; then
    echo -e "  ${GREEN}(ไม่มี)${NC}"
else
    i=1
    for entry in "${NOT_DISABLED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        config=$(echo "$entry" | cut -d'|' -f2)
        status=$(echo "$entry" | cut -d'|' -f3)
        home_label=$(echo "$entry" | cut -d'|' -f4)
        [[ "$status" == "set_but_false" ]] && label="${YELLOW}[มีค่าแต่เป็น false]${NC}" || label="${RED}[ไม่มีค่านี้เลย]${NC}"
        echo -e "  $i. ${CYAN}$domain${NC} ${PURPLE}[$home_label]${NC} $label"
        ((i++))
    done
fi

echo ""
echo -e "${GREEN}✅ เว็บที่ปิดแล้ว (ไม่มีซ้ำ) (${#DISABLED[@]} เว็บ):${NC}"
echo "------------------------------------------------------"
if [[ ${#DISABLED[@]} -eq 0 ]]; then
    echo -e "  ${GREEN}(ไม่มี)${NC}"
else
    j=1
    for entry in "${DISABLED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        home_label=$(echo "$entry" | cut -d'|' -f3)
        echo -e "  $j. ${GREEN}$domain${NC} ${PURPLE}[$home_label]${NC}"
        ((j++))
    done
fi

TOTAL=$(( ${#NOT_DISABLED[@]} + ${#DISABLED[@]} + ${#DUPLICATED[@]} ))
echo ""
echo "======================================================"
echo -e "  📊 สรุปก่อนแก้ไข:"
for path in "${SEARCH_PATHS[@]}"; do
    count=$(find "$path" -name "wp-config.php" -not -path "*/backup*" -not -name "*.bak*" 2>/dev/null | wc -l)
    echo -e "  📂 $path : ${CYAN}$count เว็บ${NC}"
done
echo -e "  🔴 ยังไม่ปิด       : ${RED}${#NOT_DISABLED[@]} เว็บ${NC}"
echo -e "  🟡 ซ้ำ (ต้องลบซ้ำ) : ${YELLOW}${#DUPLICATED[@]} เว็บ${NC}"
echo -e "  🟢 ปิดแล้ว (ปกติ)  : ${GREEN}${#DISABLED[@]} เว็บ${NC}"
echo -e "  📁 ทั้งหมด         : ${CYAN}${TOTAL} เว็บ${NC}"
echo "======================================================"
echo ""

if [[ ${#NOT_DISABLED[@]} -eq 0 && ${#DUPLICATED[@]} -eq 0 ]]; then
    echo -e "${GREEN}🎉 ทุกเว็บปิด DISABLE_WP_CRON แล้ว และไม่มีบรรทัดซ้ำ!${NC}"
    exit 0
fi

# ==================== STEP 1: แก้ไขบรรทัดซ้ำ ====================

if [[ ${#DUPLICATED[@]} -gt 0 ]]; then
    echo -e "${BLUE}🔧 STEP 1: ลบบรรทัดซ้ำ DISABLE_WP_CRON (เหลือแค่ 1 บรรทัด)...${NC}"
    echo "======================================================"
    echo ""

    DEDUP_SUCCESS=()
    DEDUP_FAILED=()

    for entry in "${DUPLICATED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        config=$(echo "$entry" | cut -d'|' -f2)
        count=$(echo "$entry" | cut -d'|' -f3)
        home_label=$(echo "$entry" | cut -d'|' -f4)

        echo -ne "  🔧 ${CYAN}$domain${NC} ${PURPLE}[$home_label]${NC} [ซ้ำ $count → 1] ... "

        # backup ก่อนแก้ไข
        cp "$config" "${config}.bak_wpcron_$(date +%Y%m%d%H%M%S)" 2>/dev/null

        # ลบบรรทัด DISABLE_WP_CRON ทั้งหมดออกก่อน
        sed -i '/DISABLE_WP_CRON/d' "$config" 2>/dev/null

        # เพิ่มกลับเข้าไป 1 บรรทัด ใต้ <?php
        sed -i '/^<?php/a define('\''DISABLE_WP_CRON'\'', true);' "$config" 2>/dev/null

        # ตรวจสอบผลลัพธ์
        new_count=$(grep -c "DISABLE_WP_CRON" "$config" 2>/dev/null)
        if [[ "$new_count" -eq 1 ]] && grep -q "define.*DISABLE_WP_CRON.*true" "$config" 2>/dev/null; then
            echo -e "${GREEN}✅ สำเร็จ (เหลือ 1 บรรทัด)${NC}"
            DEDUP_SUCCESS+=("$domain")
        else
            echo -e "${RED}❌ ล้มเหลว (พบ $new_count บรรทัด)${NC}"
            DEDUP_FAILED+=("$domain|$config")
            # restore backup
            backup_file=$(ls -t "${config}.bak_wpcron_"* 2>/dev/null | head -1)
            [[ -f "$backup_file" ]] && cp "$backup_file" "$config"
        fi
    done

    echo ""
    echo -e "  📊 ลบซ้ำ: สำเร็จ ${GREEN}${#DEDUP_SUCCESS[@]}${NC} / ล้มเหลว ${RED}${#DEDUP_FAILED[@]}${NC}"
    echo ""
fi

# ==================== STEP 2: แก้ไขเว็บที่ยังไม่ได้ปิด ====================

if [[ ${#NOT_DISABLED[@]} -gt 0 ]]; then
    echo -e "${BLUE}🔧 STEP 2: เพิ่ม/แก้ไข DISABLE_WP_CRON สำหรับเว็บที่ยังไม่ปิด...${NC}"
    echo "======================================================"
    echo ""

    SUCCESS=()
    FAILED=()

    for entry in "${NOT_DISABLED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        config=$(echo "$entry" | cut -d'|' -f2)
        status=$(echo "$entry" | cut -d'|' -f3)
        home_label=$(echo "$entry" | cut -d'|' -f4)

        echo -ne "  🔧 ${CYAN}$domain${NC} ${PURPLE}[$home_label]${NC} ... "

        # backup ก่อนแก้ไข
        cp "$config" "${config}.bak_wpcron_$(date +%Y%m%d%H%M%S)" 2>/dev/null

        if [[ "$status" == "not_set" ]]; then
            # ยังไม่มี → เพิ่มใหม่ 1 บรรทัด
            sed -i '/^<?php/a define('\''DISABLE_WP_CRON'\'', true);' "$config" 2>/dev/null
        else
            # มีแต่เป็น false → เปลี่ยนเป็น true
            sed -i "s/define( *'DISABLE_WP_CRON' *, *false *);/define('DISABLE_WP_CRON', true);/g" "$config" 2>/dev/null
            sed -i "s/define( *\"DISABLE_WP_CRON\" *, *false *);/define('DISABLE_WP_CRON', true);/g" "$config" 2>/dev/null
        fi

        if grep -q "define.*DISABLE_WP_CRON.*true" "$config" 2>/dev/null; then
            echo -e "${GREEN}✅ สำเร็จ${NC}"
            SUCCESS+=("$domain")
        else
            echo -e "${RED}❌ ล้มเหลว${NC}"
            FAILED+=("$domain|$config")
            backup_file=$(ls -t "${config}.bak_wpcron_"* 2>/dev/null | head -1)
            [[ -f "$backup_file" ]] && cp "$backup_file" "$config"
        fi
    done

    echo ""
fi

# ==================== สรุปหลังแก้ไข ====================

echo ""
echo "======================================================"
echo -e "  📊 สรุปหลังแก้ไข:"
if [[ ${#DUPLICATED[@]} -gt 0 ]]; then
    echo -e "  🟡 ลบซ้ำสำเร็จ    : ${GREEN}${#DEDUP_SUCCESS[@]} เว็บ${NC}"
    echo -e "  🟡 ลบซ้ำล้มเหลว   : ${RED}${#DEDUP_FAILED[@]} เว็บ${NC}"
fi
if [[ ${#NOT_DISABLED[@]} -gt 0 ]]; then
    echo -e "  ✅ เพิ่ม/แก้สำเร็จ : ${GREEN}${#SUCCESS[@]} เว็บ${NC}"
    echo -e "  ❌ เพิ่ม/แก้ล้มเหลว: ${RED}${#FAILED[@]} เว็บ${NC}"
fi
echo -e "  🟢 ปิดอยู่แล้ว (ปกติ): ${GREEN}${#DISABLED[@]} เว็บ${NC}"
echo -e "  📁 ทั้งหมด          : ${CYAN}${TOTAL} เว็บ${NC}"
echo "======================================================"

# แสดงรายชื่อที่ล้มเหลว
HAS_FAILURES=0
if [[ ${#DEDUP_FAILED[@]} -gt 0 ]]; then
    HAS_FAILURES=1
    echo ""
    echo -e "${RED}⚠️  เว็บที่ลบซ้ำล้มเหลว (ตรวจสอบ permission):${NC}"
    for entry in "${DEDUP_FAILED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        config=$(echo "$entry" | cut -d'|' -f2)
        echo -e "  - ${RED}$domain${NC} → $config"
    done
fi

if [[ ${#FAILED[@]} -gt 0 ]]; then
    HAS_FAILURES=1
    echo ""
    echo -e "${RED}⚠️  เว็บที่แก้ไขล้มเหลว (ตรวจสอบ permission):${NC}"
    for entry in "${FAILED[@]}"; do
        domain=$(echo "$entry" | cut -d'|' -f1)
        config=$(echo "$entry" | cut -d'|' -f2)
        echo -e "  - ${RED}$domain${NC} → $config"
    done
fi

echo ""
echo -e "${YELLOW}💡 Backup: wp-config.php.bak_wpcron_YYYYMMDDHHMMSS${NC}"
echo ""
